@model ATS.Core.Entities.Assessment

@{
    ViewData["Title"] = "Add Assessment";
}

<section class="form-page-shell form-page-shell--compact">
    <div class="form-page-hero">
        <div>
            <div class="form-page-eyebrow">Assessment</div>
            <h1 class="form-page-title">Add an assessment</h1>
            <p class="form-page-subtitle mb-0">
                Add an assignment, quiz, test, or exam so you can keep track of what is coming up.
            </p>
        </div>
        <a asp-action="Index" class="btn btn-outline-primary form-page-back">
            <i class="bi bi-arrow-left-short"></i>
            Back to assessments
        </a>
    </div>

    <div class="form-page-panel">
        <div class="form-card">
            <div class="form-card-header">
                <div class="form-card-icon">
                    <i class="bi bi-clipboard-plus"></i>
                </div>
                <div>
                    <h2 class="form-card-title">Assessment details</h2>
                    <p class="form-card-copy mb-0">Add the basics now so it is easier to stay on top of your work.</p>
                </div>
            </div>

            <form asp-action="Create" method="post" class="form-page-form">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger form-validation-summary" role="alert"></div>

                <div class="form-field">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control form-control-lg" placeholder="Example: Midterm Presentation" />
                    <div class="form-field-hint">Use the same name your instructor or course outline uses when possible.</div>
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-field form-field-grid">
                    <div>
                        <label asp-for="CourseId" class="form-label">Course</label>
                        <select asp-for="CourseId" class="form-select form-select-lg" asp-items="ViewBag.CourseId"></select>
                        <div class="form-field-hint">Choose the course this assessment belongs to.</div>
                        <span asp-validation-for="CourseId" class="text-danger"></span>
                    </div>

                    <div>
                        <label class="form-label">Due Date</label>
                        <input asp-for="DueDate" type="date" class="form-control form-control-lg" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        <div class="form-field-hint">Pick the date you want to remember and see on the calendar.</div>
                        <span asp-validation-for="DueDate" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-field">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select form-select-lg">
                        <option>Not Started</option>
                        <option>In Progress</option>
                    </select>
                    <div class="form-field-hint">Choose the option that best matches where you are right now.</div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check2-circle me-1"></i>
                        Save assessment
                    </button>
                    <a asp-action="Index" class="btn btn-light btn-lg">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
