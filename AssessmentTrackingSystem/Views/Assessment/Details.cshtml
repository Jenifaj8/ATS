@model ATS.Core.Entities.Assessment

@{
    ViewData["Title"] = "Assessment Details";
}

<style>
    .details-page-shell {
        max-width: 1080px;
        margin: 0 auto;
        display: grid;
        gap: 1.5rem;
    }

    .details-page-hero {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 1.25rem;
        flex-wrap: wrap;
        padding: 1.75rem;
        border: 1px solid rgba(147, 197, 253, 0.45);
        border-radius: 1.5rem;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.92) 0%, rgba(238, 244, 255, 0.96) 58%, rgba(255, 248, 238, 0.96) 100%);
        box-shadow: 0 20px 45px rgba(37, 99, 235, 0.08);
    }

    .details-page-eyebrow {
        margin-bottom: 0.65rem;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #0b5ed7;
    }

    .details-page-title {
        margin-bottom: 0.4rem;
        font-size: clamp(2rem, 3vw, 2.65rem);
        line-height: 1.05;
    }

    .details-page-subtitle {
        max-width: 42rem;
        margin-bottom: 0;
        color: #475569;
        font-size: 1.02rem;
    }

    .details-page-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .details-page-panel {
        max-width: 820px;
        width: 100%;
        margin: 0 auto;
        border: 1px solid rgba(203, 213, 225, 0.95);
        border-radius: 1.5rem;
        background: rgba(255, 255, 255, 0.94);
        box-shadow: 0 18px 45px rgba(15, 23, 42, 0.06);
        overflow: hidden;
    }

    .details-page-panel-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.5rem 1.75rem 0;
    }

    .details-page-icon {
        width: 3.25rem;
        height: 3.25rem;
        border-radius: 1rem;
        display: inline-grid;
        place-items: center;
        flex-shrink: 0;
        font-size: 1.3rem;
        color: #fff;
        background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
        box-shadow: 0 12px 30px rgba(37, 99, 235, 0.24);
    }

    .details-page-panel-title {
        margin-bottom: 0.25rem;
        font-size: 1.3rem;
    }

    .details-page-panel-copy {
        margin-bottom: 0;
        color: #64748b;
    }

    .details-page-content {
        padding: 1.5rem 1.75rem 1.75rem;
    }

    .details-grid {
        display: grid;
        gap: 1rem;
    }

    .details-row {
        display: grid;
        grid-template-columns: minmax(140px, 180px) 1fr;
        gap: 1rem;
        align-items: start;
        padding: 1rem 1.1rem;
        border-radius: 1rem;
        background: #f8fbff;
        border: 1px solid #e2e8f0;
    }

    .details-label {
        margin: 0;
        color: #475569;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .details-value {
        margin: 0;
        color: #1e293b;
        font-size: 1rem;
        font-weight: 600;
    }

    .details-status {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 120px;
        padding: 0.45rem 0.8rem;
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .details-status--not-started {
        background: #fff3cd;
        color: #946200;
    }

    .details-status--in-progress {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .details-status--completed {
        background: #dcfce7;
        color: #166534;
    }

    .details-status--default {
        background: #e2e8f0;
        color: #334155;
    }

    @@media (max-width: 767.98px) {
        .details-page-hero,
        .details-page-content {
            padding: 1.25rem;
        }

        .details-page-panel-header {
            padding: 1.25rem 1.25rem 0;
        }

        .details-page-actions {
            width: 100%;
        }

        .details-page-actions .btn {
            flex: 1 1 100%;
        }

        .details-row {
            grid-template-columns: 1fr;
            gap: 0.4rem;
        }
    }
</style>

@{
    var statusClass = Model.Status switch
    {
        "Not Started" => "details-status--not-started",
        "In Progress" => "details-status--in-progress",
        "Completed" => "details-status--completed",
        _ => "details-status--default"
    };
}

<section class="details-page-shell">
    <div class="details-page-hero">
        <div>
            <div class="details-page-eyebrow">Assessment</div>
            <h1 class="details-page-title">@Model.Name</h1>
            <p class="details-page-subtitle">Review the course, due date, and current progress for this assessment.</p>
        </div>

        <div class="details-page-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                <i class="bi bi-pencil-square me-1"></i>Edit
            </a>
            <a asp-action="Index" class="btn btn-outline-primary">
                <i class="bi bi-arrow-left-short me-1"></i>Back to list
            </a>
        </div>
    </div>

    <div class="details-page-panel">
        <div class="details-page-panel-header">
            <div class="details-page-icon">
                <i class="bi bi-clipboard-data"></i>
            </div>
            <div>
                <h2 class="details-page-panel-title">Assessment information</h2>
                <p class="details-page-panel-copy">Everything important about this item is grouped here in one place.</p>
            </div>
        </div>

        <div class="details-page-content">
            <div class="details-grid">
                <div class="details-row">
                    <p class="details-label">Name</p>
                    <p class="details-value">@Model.Name</p>
                </div>

                <div class="details-row">
                    <p class="details-label">Course</p>
                    <p class="details-value">@Model.Course?.Name</p>
                </div>

                <div class="details-row">
                    <p class="details-label">Due Date</p>
                    <p class="details-value">@Model.DueDate.ToShortDateString()</p>
                </div>

                <div class="details-row">
                    <p class="details-label">Status</p>
                    <div>
                        <span class="details-status @statusClass">@Model.Status</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
