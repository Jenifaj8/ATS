@model ATS.Core.Entities.Assessment

@{
    ViewData["Title"] = "Delete Assessment";
}

<style>
    .delete-page-shell {
        max-width: 1080px;
        margin: 0 auto;
        display: grid;
        gap: 1.5rem;
    }

    .delete-page-hero {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 1.25rem;
        flex-wrap: wrap;
        padding: 1.75rem;
        border: 1px solid rgba(248, 113, 113, 0.3);
        border-radius: 1.5rem;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.94) 0%, rgba(254, 242, 242, 0.96) 56%, rgba(255, 247, 237, 0.96) 100%);
        box-shadow: 0 20px 45px rgba(239, 68, 68, 0.08);
        color: var(--app-text-color);
    }

    .delete-page-eyebrow {
        margin-bottom: 0.65rem;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #dc2626;
    }

    .delete-page-title {
        margin-bottom: 0.4rem;
        font-size: clamp(2rem, 3vw, 2.65rem);
        line-height: 1.05;
    }

    .delete-page-subtitle {
        max-width: 42rem;
        margin-bottom: 0;
        color: var(--app-muted-color);
        font-size: 1.02rem;
    }

    .delete-page-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .delete-page-panel {
        width: 100%;
        border: 1px solid rgba(203, 213, 225, 0.95);
        border-radius: 1.5rem;
        background: rgba(255, 255, 255, 0.94);
        box-shadow: 0 18px 45px rgba(15, 23, 42, 0.06);
        overflow: hidden;
        color: var(--app-text-color);
    }

    .delete-page-warning {
        margin: 1.5rem 1.75rem 0;
        padding: 1rem 1.1rem;
        border: 1px solid #fecaca;
        border-radius: 1rem;
        background: #fef2f2;
        color: #991b1b;
    }

    .delete-page-warning h4 {
        margin: 0 0 0.35rem;
        font-size: 1.05rem;
    }

    .delete-page-warning p {
        margin: 0;
    }

    .delete-page-content {
        padding: 1.5rem 1.75rem 1.75rem;
    }

    .delete-grid {
        display: grid;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .delete-row {
        display: grid;
        grid-template-columns: minmax(140px, 180px) 1fr;
        gap: 1rem;
        align-items: start;
        padding: 1rem 1.1rem;
        border-radius: 1rem;
        background: #fff7f7;
        border: 1px solid #fee2e2;
    }

    .delete-label {
        margin: 0;
        color: #7f1d1d;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .delete-value {
        margin: 0;
        color: var(--app-text-color);
        font-size: 1rem;
        font-weight: 600;
    }

    .delete-status {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 120px;
        padding: 0.45rem 0.8rem;
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .delete-status--not-started {
        background: #fff3cd;
        color: #946200;
    }

    .delete-status--in-progress {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .delete-status--completed {
        background: #dcfce7;
        color: #166534;
    }

    .delete-status--default {
        background: #e2e8f0;
        color: #334155;
    }

    .delete-form-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
    }

    html[data-theme="dark"] .delete-page-hero,
    html[data-theme="dark"] .delete-page-panel {
        background: rgba(17, 24, 39, 0.96);
        border-color: #334155;
        box-shadow: 0 14px 30px rgba(2, 6, 23, 0.28);
        color: #e5ecff;
    }

    html[data-theme="dark"] .delete-page-title,
    html[data-theme="dark"] .delete-value {
        color: #e5ecff !important;
    }

    html[data-theme="dark"] .delete-page-subtitle {
        color: #a8b3cf !important;
    }

    html[data-theme="dark"] .delete-page-actions .btn-outline-primary,
    html[data-theme="dark"] .delete-page-actions .btn-outline-secondary {
        border-color: #475569;
        color: #e5ecff;
    }

    html[data-theme="dark"] .delete-page-actions .btn-outline-primary:hover,
    html[data-theme="dark"] .delete-page-actions .btn-outline-primary:focus,
    html[data-theme="dark"] .delete-page-actions .btn-outline-secondary:hover,
    html[data-theme="dark"] .delete-page-actions .btn-outline-secondary:focus {
        background: rgba(30, 41, 59, 0.92);
        border-color: #64748b;
        color: #ffffff;
    }

    html[data-theme="dark"] .delete-page-warning {
        background: rgba(127, 29, 29, 0.16);
        border-color: rgba(248, 113, 113, 0.35);
        color: #fecaca;
    }

    html[data-theme="dark"] .delete-row {
        background: rgba(15, 23, 42, 0.9);
        border-color: #334155;
    }

    html[data-theme="dark"] .delete-label {
        color: #fca5a5;
    }

    html[data-theme="dark"] .delete-form-actions .btn-light {
        background: #334155;
        border-color: #334155;
        color: #e5ecff;
    }

    html[data-theme="dark"] .delete-form-actions .btn-light:hover,
    html[data-theme="dark"] .delete-form-actions .btn-light:focus {
        background: #475569;
        border-color: #475569;
        color: #ffffff;
    }

    @@media (max-width: 767.98px) {
        .delete-page-hero,
        .delete-page-content {
            padding: 1.25rem;
        }

        .delete-page-warning {
            margin: 1.25rem 1.25rem 0;
        }

        .delete-page-actions,
        .delete-form-actions {
            width: 100%;
        }

        .delete-page-actions .btn,
        .delete-form-actions .btn {
            flex: 1 1 100%;
        }

        .delete-row {
            grid-template-columns: 1fr;
            gap: 0.4rem;
        }
    }
</style>

@{
    var statusClass = Model.Status switch
    {
        "Not Started" => "delete-status--not-started",
        "In Progress" => "delete-status--in-progress",
        "Completed" => "delete-status--completed",
        _ => "delete-status--default"
    };
}

<section class="delete-page-shell">
    <div class="delete-page-hero">
        <div>
            <div class="delete-page-eyebrow">Assessment</div>
            <h1 class="delete-page-title">Delete assessment</h1>
            <p class="delete-page-subtitle">Review the details below before removing this assessment from your list.</p>
        </div>

        <div class="delete-page-actions">
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                <i class="bi bi-eye me-1"></i>View details
            </a>
            <a asp-action="Index" class="btn btn-outline-primary">
                <i class="bi bi-arrow-left-short me-1"></i>Back to list
            </a>
        </div>
    </div>

    <div class="delete-page-panel">
        <div class="delete-page-warning">
            <h4>Are you sure you want to delete this assessment?</h4>
            <p>This action removes the assessment from your tracker and cannot be undone.</p>
        </div>

        <div class="delete-page-content">
            <div class="delete-grid">
                <div class="delete-row">
                    <p class="delete-label">Name</p>
                    <p class="delete-value">@Model.Name</p>
                </div>

                <div class="delete-row">
                    <p class="delete-label">Course</p>
                    <p class="delete-value">@Model.Course?.Name</p>
                </div>

                <div class="delete-row">
                    <p class="delete-label">Due Date</p>
                    <p class="delete-value">@Model.DueDate.ToShortDateString()</p>
                </div>

                <div class="delete-row">
                    <p class="delete-label">Status</p>
                    <div>
                        <span class="delete-status @statusClass">@Model.Status</span>
                    </div>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="delete-form-actions">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash3 me-1"></i>Delete assessment
                    </button>
                    <a asp-action="Index" class="btn btn-light">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</section>
