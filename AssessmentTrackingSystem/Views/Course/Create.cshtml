@model ATS.Core.Entities.Course

@{
    ViewData["Title"] = "Add Course";
}

<style>
    .form-page-shell {
        max-width: 1080px;
        margin: 0 auto;
        display: grid;
        gap: 1.5rem;
    }

    .form-page-hero {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 1.25rem;
        padding: 1.75rem;
        border: 1px solid rgba(147, 197, 253, 0.45);
        border-radius: 1.5rem;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.92) 0%, rgba(238, 244, 255, 0.96) 58%, rgba(255, 248, 238, 0.96) 100%);
        box-shadow: 0 20px 45px rgba(37, 99, 235, 0.08);
        color: var(--app-text-color);
    }

    .form-page-eyebrow {
        margin-bottom: 0.65rem;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #0b5ed7;
    }

    .form-page-title {
        margin-bottom: 0.5rem;
        font-size: clamp(2rem, 3vw, 2.65rem);
        line-height: 1.05;
    }

    .form-page-subtitle {
        max-width: 42rem;
        color: var(--app-muted-color);
        font-size: 1.02rem;
    }

    .form-page-back {
        white-space: nowrap;
        align-self: center;
    }

    .form-page-panel {
        width: 100%;
    }

    .form-card {
        padding: 1.75rem;
        border: 1px solid rgba(203, 213, 225, 0.95);
        border-radius: 1.5rem;
        background: rgba(255, 255, 255, 0.94);
        box-shadow: 0 18px 45px rgba(15, 23, 42, 0.06);
        color: var(--app-text-color);
    }

    .form-card-header {
        display: flex;
        align-items: start;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .form-card-icon {
        width: 3.25rem;
        height: 3.25rem;
        border-radius: 1rem;
        display: inline-grid;
        place-items: center;
        flex-shrink: 0;
        font-size: 1.3rem;
        color: #fff;
        background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
        box-shadow: 0 12px 30px rgba(37, 99, 235, 0.24);
    }

    .form-card-title {
        margin-bottom: 0.35rem;
        font-size: 1.35rem;
    }

    .form-card-copy {
        color: var(--app-muted-color);
    }

    .form-page-form {
        display: grid;
        gap: 1.25rem;
    }

    .form-validation-summary:empty {
        display: none;
    }

    .form-validation-summary ul {
        margin-bottom: 0;
        padding-left: 1.1rem;
    }

    .form-field {
        display: grid;
        gap: 0.45rem;
    }

    .form-field .form-control {
        border-radius: 1rem;
        border-color: #d7dfeb;
        background-color: #fbfdff;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    }

    .form-field .form-control:hover {
        border-color: #b7c7e6;
    }

    .form-field .form-control:focus {
        transform: translateY(-1px);
        background-color: #fff;
    }

    .form-field-hint {
        color: var(--app-muted-color);
        font-size: 0.92rem;
    }

    html[data-theme="dark"] .form-page-hero,
    html[data-theme="dark"] .form-card {
        background: rgba(17, 24, 39, 0.96);
        border-color: #334155;
        box-shadow: 0 14px 30px rgba(2, 6, 23, 0.28);
        color: #e5ecff;
    }

    html[data-theme="dark"] .form-page-title,
    html[data-theme="dark"] .form-card-title,
    html[data-theme="dark"] .form-label {
        color: #e5ecff !important;
    }

    html[data-theme="dark"] .form-page-subtitle,
    html[data-theme="dark"] .form-card-copy,
    html[data-theme="dark"] .form-field-hint {
        color: #a8b3cf !important;
    }

    html[data-theme="dark"] .form-page-back.btn-outline-primary {
        color: #e5ecff;
        border-color: #475569;
    }

    html[data-theme="dark"] .form-page-back.btn-outline-primary:hover,
    html[data-theme="dark"] .form-page-back.btn-outline-primary:focus {
        background: rgba(30, 41, 59, 0.92);
        border-color: #64748b;
        color: #ffffff;
    }

    html[data-theme="dark"] .form-field .form-control {
        background-color: #0f172a;
        border-color: #334155;
        color: #e5ecff;
    }

    html[data-theme="dark"] .form-field .form-control:hover,
    html[data-theme="dark"] .form-field .form-control:focus {
        background-color: #111827;
        border-color: #475569;
        color: #e5ecff;
    }

    html[data-theme="dark"] .form-actions .btn-light {
        background: #334155;
        border-color: #334155;
        color: #e5ecff;
    }

    html[data-theme="dark"] .form-actions .btn-light:hover,
    html[data-theme="dark"] .form-actions .btn-light:focus {
        background: #475569;
        border-color: #475569;
        color: #ffffff;
    }

    .form-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        padding-top: 0.5rem;
    }

    @@media (max-width: 767.98px) {
        .form-page-hero,
        .form-card {
            padding: 1.25rem;
        }

        .form-card-header {
            align-items: flex-start;
            flex-direction: column;
        }

        .form-page-back {
            width: 100%;
            justify-content: center;
        }

        .form-actions {
            flex-direction: column;
        }

        .form-actions .btn {
            width: 100%;
        }
    }

    @@media (max-width: 575.98px) {
        .form-page-title {
            font-size: 1.9rem;
        }

        .form-page-subtitle,
        .form-card-copy,
        .form-field-hint {
            font-size: 0.95rem;
        }
    }
</style>

<section class="form-page-shell">
    <div class="form-page-hero">
        <div>
            <div class="form-page-eyebrow">Course</div>
            <h1 class="form-page-title">Add a course</h1>
            <p class="form-page-subtitle mb-0">
                Add your course name and code so your school work stays organized in one place.
            </p>
        </div>
        <a asp-action="Index" class="btn btn-outline-primary form-page-back">
            <i class="bi bi-arrow-left-short"></i>
            Back to courses
        </a>
    </div>

    <div class="form-page-panel">
        <div class="form-card">
            <div class="form-card-header">
                <div class="form-card-icon">
                    <i class="bi bi-journal-plus"></i>
                </div>
                <div>
                    <h2 class="form-card-title">Course details</h2>
                    <p class="form-card-copy mb-0">Keep the information clear and easy to recognize later.</p>
                </div>
            </div>

            <form asp-action="Create" method="post" class="form-page-form">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger form-validation-summary" role="alert"></div>

                <div class="form-field">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control form-control-lg" placeholder="Example: Mobile App Development" />
                    <div class="form-field-hint">Use the course name you would expect to see on your timetable or syllabus.</div>
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Code" class="form-label"></label>
                    <input asp-for="Code" class="form-control form-control-lg" placeholder="Example: CSD214" />
                    <div class="form-field-hint">Add the short course code so it is easier to spot in lists.</div>
                    <span asp-validation-for="Code" class="text-danger"></span>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check2-circle me-1"></i>
                        Save course
                    </button>
                    <a asp-action="Index" class="btn btn-light btn-lg">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
