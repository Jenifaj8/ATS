@model List<ATS.Core.Entities.Course>

@{
    ViewData["Title"] = "Courses";
}

<section class="course-page-header mb-4">
    <div>
        <h1 class="mb-2">My Courses</h1>
        <p class="text-muted mb-0">Add a course and it will show up here as a card.</p>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add Course
    </a>
</section>

@if (Model == null || !Model.Any())
{
    <div class="course-empty-state">
        <div class="course-empty-icon">
            <i class="bi bi-journal-richtext"></i>
        </div>
        <h2>No courses yet</h2>
        <p class="text-muted">Start by adding your first course, and it will appear here as a card.</p>
        <a asp-action="Create" class="btn btn-primary">Create First Course</a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var course in Model)
        {
            var assessmentCount = course.Assessments?.Count ?? 0;

            <div class="col-12 col-md-6 col-xl-4">
                <article class="card h-100 shadow-sm border-0 course-card">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <p class="course-card-code mb-2">@course.Code</p>
                                <h2 class="h4 mb-0">@course.Name</h2>
                            </div>
                            <span class="badge rounded-pill text-bg-light course-card-badge">
                                @assessmentCount @(assessmentCount == 1 ? "assessment" : "assessments")
                            </span>
                        </div>

                        <p class="text-muted mb-4">
                            Track deadlines, quizzes, exams, and course work for @course.Code.
                        </p>

                        <div class="mt-auto d-flex flex-wrap gap-2">
                            <a asp-action="Details" asp-route-id="@course.Id" class="btn btn-outline-primary btn-sm">View</a>
                            <a asp-action="Edit" asp-route-id="@course.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
                            <a asp-action="Delete" asp-route-id="@course.Id" class="btn btn-outline-danger btn-sm">Delete</a>
                        </div>
                    </div>
                </article>
            </div>
        }
    </div>
}
