@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-4">
    <h1 class="mb-4">Privacy Policy</h1>

    <p class="lead">
        <strong>The Assessment Tracking System (ATS) is designed to support users in managing courses,
        assessments, deadlines, and academic information in a structured and secure environment.</strong>
    </p>

    <hr class="my-4" />

    <h3>Information Stored in the System</h3>
    <ul>
        <li>Course details</li>
        <li>Assessment records</li>
        <li>Assessment due dates</li>
    </ul>

    <h3>How Information Is Used</h3>
    <ul>
        <li>To support system functionality</li>
        <li>To organize and track academic information</li>
        <li>To allow users to manage courses and assessments efficiently</li>
    </ul>

    <h3>Security and Access Control</h3>
    <ul>
        <li>User authentication is implemented to protect accounts</li>
        <li>Authorization controls restrict access based on user permissions</li>
        <li>Only authorized users can access and manage their information</li>
    </ul>

    <h3>Data Protection</h3>
    <ul>
        <li>ATS does not share user data with third parties</li>
        <li>All information is maintained within the system database</li>
        <li>Data is handled according to standard data protection practices</li>
    </ul>

    <h3>Project Purpose</h3>
    <p>
        This application has been developed with a focus on privacy, security, and responsible
        data management as part of an academic project.
    </p>
</div>