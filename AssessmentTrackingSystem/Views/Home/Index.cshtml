@model AssessmentTrackingSystem.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">

    <h1 class="mb-4">Dashboard</h1>

    <a asp-controller="Assessment" asp-action="Create" class="btn btn-primary mb-3">
        Add New Assessment
    </a>

    <div class="row mb-4">

        <a asp-controller="Course" asp-action="Index" class="col-md-3 text-decoration-none">
            <div class="card bg-primary text-white mb-3">
                <div class="card-body">
                    <h5>Total Courses</h5>
                    <h2>@Model.TotalCourses</h2>
                </div>
            </div>
        </a>

        <a asp-controller="Assessment" asp-action="Index" class="col-md-3 text-decoration-none">
            <div class="card bg-success text-white mb-3">
                <div class="card-body">
                    <h5>Total Assessments</h5>
                    <h2>@Model.TotalAssessments</h2>
                </div>
            </div>
        </a>

        <a asp-controller="Assessment" asp-action="Index" class="col-md-2 text-decoration-none">
            <div class="card bg-secondary text-white mb-3">
                <div class="card-body">
                    <h6>Not Started</h6>
                    <h3>@Model.NotStartedCount</h3>
                </div>
            </div>
        </a>

        <a asp-controller="Assessment" asp-action="Index" class="col-md-2 text-decoration-none">
            <div class="card bg-warning text-dark mb-3">
                <div class="card-body">
                    <h6>In Progress</h6>
                    <h3>@Model.InProgressCount</h3>
                </div>
            </div>
        </a>

        <a asp-controller="Assessment" asp-action="Index" class="col-md-2 text-decoration-none">
            <div class="card bg-info text-white mb-3">
                <div class="card-body">
                    <h6>Completed</h6>
                    <h3>@Model.CompletedCount</h3>
                </div>
            </div>
        </a>

    </div>


    <div class="row">

        <div class="col-md-6">

            <h3>Upcoming Assessments</h3>

            @if (Model.UpcomingAssessments.Any())
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Course</th>
                            <th>Due Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>
                    @foreach (var assessment in Model.UpcomingAssessments)
                    {
                        <tr>
                            <td>@assessment.Name</td>
                            <td>@assessment.Course?.Name</td>
                            <td>@assessment.DueDate.ToString("yyyy-MM-dd")</td>
                            <td>@assessment.Status</td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
            else
            {
                <p>No upcoming assessments in the next 7 days.</p>
            }

        </div>


        <div class="col-md-6">

            <h3>Overdue Assessments</h3>

            @if (Model.OverdueAssessments.Any())
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Course</th>
                            <th>Due Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>
                    @foreach (var assessment in Model.OverdueAssessments)
                    {
                        <tr class="table-danger">
                            <td>@assessment.Name</td>
                            <td>@assessment.Course?.Name</td>
                            <td>@assessment.DueDate.ToString("yyyy-MM-dd")</td>
                            <td>@assessment.Status</td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
            else
            {
                <p>No overdue assessments.</p>
            }

        </div>

    </div>

</div>
