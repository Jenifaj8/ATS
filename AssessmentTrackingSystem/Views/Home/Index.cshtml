@using ATS.Core.Entities
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-4">
    <section class="home-page-header text-center">
        <div class="home-page-title-wrap">
            @if (!SignInManager.IsSignedIn(User))
            {
                <span class="app-brand-mark home-page-brand-mark" aria-hidden="true">
                    <img src="~/ATS-LOGO.png" alt="" class="app-brand-image" />
                </span>
            }
            <h1 class="display-4 fw-bold mb-3">Assessment Tracking System</h1>
        </div>
        <p class="lead mb-0">
            Organize your courses, track your assessments, and stay on top of your deadlines.
        </p>
    </section>

    @if (!SignInManager.IsSignedIn(User))
    {
        <div class="home-card text-center">
            <h2 class="fw-bold mb-3">Get Started</h2>
            <p class="mb-4">
                Create an account or log in to begin managing your courses and assessments.
            </p>

            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-lg px-4">
                    Register
                </a>
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg px-4">
                    Login
                </a>
            </div>
        </div>

        <div class="row g-4 text-center mb-5">
            <div class="col-md-4">
                <div class="feature-box h-100">
                    <i class="bi bi-journal-check feature-icon"></i>
                    <h4 class="mt-3">Track Assessments</h4>
                    <p class="mb-0">Keep all assignments, quizzes, tests, and deadlines in one place.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-box h-100">
                    <i class="bi bi-book feature-icon"></i>
                    <h4 class="mt-3">Manage Courses</h4>
                    <p class="mb-0">Organize your courses and connect them to your assessments.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-box h-100">
                    <i class="bi bi-calendar-event feature-icon"></i>
                    <h4 class="mt-3">View Agenda</h4>
                    <p class="mb-0">Stay aware of upcoming work and manage your academic schedule.</p>
                </div>
            </div>
        </div>
    }
    else
    {
        var currentUser = await UserManager.GetUserAsync(User);

        <div class="home-card text-center">
            <h2 class="fw-bold mb-3">
                Welcome back, @(currentUser?.FirstName ?? "User")! 👋
            </h2>
            <p class="mb-4">What would you like to do today?</p>
            
            <div class="mb-4">
                <a asp-controller="Home" asp-action="Dashboard" class="btn btn-success btn-lg px-4">
                    Go to Dashboard
                </a>
            </div>

            <div class="row g-4 mt-3">
                <div class="col-md-4">
                    <a asp-controller="Assessment" asp-action="Index" class="action-card text-decoration-none">
                        <i class="bi bi-journal-check action-icon"></i>
                        <h5 class="mt-3">Track Assessments</h5>
                        <p class="text-muted">View and manage your assessments</p>
                    </a>
                </div>

                <div class="col-md-4">
                    <a asp-controller="Course" asp-action="Index" class="action-card text-decoration-none">
                        <i class="bi bi-book action-icon"></i>
                        <h5 class="mt-3">Courses</h5>
                        <p class="text-muted">Manage your courses</p>
                    </a>
                </div>

                <div class="col-md-4">
                    <a asp-controller="Calendar" asp-action="Index" class="action-card text-decoration-none">
                        <i class="bi bi-calendar-event action-icon"></i>
                        <h5 class="mt-3">Agenda</h5>
                        <p class="text-muted">View your schedule</p>
                    </a>
                </div>
            </div>
        </div>
    }

</div>
