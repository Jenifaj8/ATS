@model List<ATS.Core.Entities.Assessment>

@{
    var selectedStatus = ViewBag.SelectedStatus as string ?? "Assessments";
    ViewData["Title"] = $"{selectedStatus} Assessments";
}

<section class="dashboard-hero">
    <div>
        <p class="dashboard-eyebrow mb-2">Dashboard Filter</p>
        <h1 class="mb-2">@selectedStatus Assessments</h1>
        <p class="text-muted mb-0">This view belongs to the dashboard area, so it won't interfere with the assessments module.</p>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Dashboard" class="btn btn-outline-primary">Back to Dashboard</a>
        <a asp-controller="Assessment" asp-action="Index" class="btn btn-primary">Open All Assessments</a>
    </div>
</section>

@if (!Model.Any())
{
    <article class="dashboard-panel">
        <p class="text-muted mb-0">No assessments found with status <strong>@selectedStatus</strong>.</p>
    </article>
}
else
{
    <article class="dashboard-panel">
        <div class="dashboard-panel-header">
            <div>
                <p class="dashboard-panel-kicker mb-1">Filtered Results</p>
                <h2 class="h4 mb-0">@selectedStatus</h2>
            </div>
            <span class="badge rounded-pill text-bg-light">@Model.Count</span>
        </div>

        <div class="dashboard-list">
            @foreach (var assessment in Model)
            {
                <div class="dashboard-list-item">
                    <div>
                        <h3 class="h6 mb-1">@assessment.Name</h3>
                        <p class="text-muted mb-0">@assessment.Course?.Name - @assessment.DueDate.ToString("MMM dd, yyyy")</p>
                    </div>
                    <div class="d-flex flex-wrap gap-2 align-items-center">
                        <span class="badge text-bg-light border">@assessment.Status</span>
                        <a asp-controller="Assessment" asp-action="Details" asp-route-id="@assessment.Id" class="btn btn-outline-primary btn-sm">Details</a>
                    </div>
                </div>
            }
        </div>
    </article>
}
