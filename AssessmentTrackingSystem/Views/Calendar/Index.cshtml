@model AssessmentTrackingSystem.Models.CalendarViewModel

@{
    ViewData["Title"] = "Calendar";
    var previousWeek = Model.WeekStart.AddDays(-7);
    var nextWeek = Model.WeekStart.AddDays(7);
    var previousWeekRoute = previousWeek.ToString("yyyy-MM-dd");
    var currentWeekRoute = DateTime.Today.ToString("yyyy-MM-dd");
    var nextWeekRoute = nextWeek.ToString("yyyy-MM-dd");
}

<section class="calendar-shell">
    <aside class="calendar-sidebar">
        <div class="calendar-brand">
            <div class="calendar-brand__icon">
                <i class="bi bi-calendar3"></i>
            </div>
            <div>
                <p class="calendar-brand__eyebrow">Planner</p>
                <h1 class="calendar-brand__title">Schedule</h1>
            </div>
        </div>

        <nav class="calendar-nav">
            <a class="calendar-nav__link" asp-controller="Assessment" asp-action="Create">
                <i class="bi bi-plus-square"></i>
                Add Task
            </a>
            <a class="calendar-nav__link" asp-controller="Assessment" asp-action="Index">
                <i class="bi bi-journal-text"></i>
                Assessments
            </a>
            <a class="calendar-nav__link" asp-controller="Course" asp-action="Index">
                <i class="bi bi-book"></i>
                Courses
            </a>
        </nav>

        <div class="calendar-summary">
            <p class="calendar-summary__label">This Week</p>
            <p class="calendar-summary__count">@Model.TaskSummaryLabel</p>
        </div>
    </aside>

    <div class="calendar-board">
        <header class="calendar-board__header">
            <div>
                <p class="calendar-board__eyebrow">Weekly Planner</p>
                <h2 class="calendar-board__title">
                    @Model.WeekStart.ToString("MMMM d") - @Model.WeekEnd.ToString("MMMM d, yyyy")
                </h2>
            </div>

            <div class="calendar-board__actions">
                <a class="calendar-action" asp-action="Index" asp-route-weekStart="@previousWeekRoute" aria-label="Previous week">
                    <i class="bi bi-chevron-left"></i>
                </a>
                <a class="calendar-action" asp-action="Index" asp-route-weekStart="@currentWeekRoute">
                    Today
                </a>
                <a class="calendar-action" asp-action="Index" asp-route-weekStart="@nextWeekRoute" aria-label="Next week">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </div>
        </header>

        <div class="calendar-grid">
            @foreach (var day in Model.Days)
            {
                <section class="calendar-day @(day.Date.Date == DateTime.Today ? "calendar-day--today" : string.Empty)">
                    <header class="calendar-day__header">
                        <p class="calendar-day__name">@day.Date.ToString("dddd")</p>
                        <p class="calendar-day__date">@day.Date.ToString("MMM d")</p>
                    </header>

                    <div class="calendar-day__body">
                        @if (day.Items.Any())
                        {
                            foreach (var item in day.Items)
                            {
                                <a class="calendar-item @item.AccentClass" asp-controller="Assessment" asp-action="Details" asp-route-id="@item.Id">
                                    <p class="calendar-item__category">@item.Category</p>
                                    <h3 class="calendar-item__title">@item.Title</h3>
                                    <p class="calendar-item__course">@item.CourseName</p>
                                    <div class="calendar-item__meta">
                                        <span>@item.Status</span>
                                    </div>
                                </a>
                            }
                        }
                        else
                        {
                            <div class="calendar-empty">
                                <span>No tasks due</span>
                            </div>
                        }
                    </div>
                </section>
            }
        </div>
    </div>
</section>
