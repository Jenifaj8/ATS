<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - AssessmentTrackingSystem</title>
    <script>
        (function () {
            var savedTheme = localStorage.getItem("app-theme");
            var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
            var theme = savedTheme || (prefersDark ? "dark" : "light");
            document.documentElement.setAttribute("data-theme", theme);
        })();
    </script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/AssessmentTrackingSystem.styles.css" asp-append-version="true"/>
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm app-navbar border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Assessment Tracking System</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">

                    <li class="nav-item">
                        <a class="nav-link app-nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door me-1"></i> Home
                        </a>
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link app-nav-link" asp-area="" asp-controller="Home" asp-action="Dashboard">
                            <i class="bi bi-grid-1x2 me-1"></i> Dashboard
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link app-nav-link" asp-controller="Course" asp-action="Index">
                            <i class="bi bi-journal-bookmark me-1"></i> Courses
                        </a>
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link app-nav-link" asp-controller="Assessment" asp-action="Index">
                            <i class="bi bi-clipboard-check me-1"></i> Assessments
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link app-nav-link" asp-controller="Calendar" asp-action="Index">
                            <i class="bi bi-calendar-week me-1"></i> Calendar
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link app-nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">
                            <i class="bi bi-shield-lock me-1"></i> Privacy
                        </a>
                    </li>

                </ul>

            </div>
        </div>
    </nav>
</header>

<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer app-footer">
    <div class="container app-footer-content">
        <div>
            &copy; 2026 - AssessmentTrackingSystem - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
        <button type="button" class="btn app-theme-toggle" data-theme-toggle aria-label="Switch between light mode and dark mode">
            <i class="bi bi-moon-stars-fill" data-theme-icon></i>
            <span data-theme-label>Dark Mode</span>
        </button>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
