@using ATS.Core.Entities
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AssessmentTrackingSystem</title>

    <script>
        (function () {
            var savedTheme = localStorage.getItem("app-theme");
            var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
            var theme = savedTheme || (prefersDark ? "dark" : "light");
            document.documentElement.setAttribute("data-theme", theme);
        })();
    </script>

    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AssessmentTrackingSystem.styles.css" asp-append-version="true" />
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm app-navbar border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                @if (SignInManager.IsSignedIn(User))
                {
                    <span class="app-brand-mark" aria-hidden="true">
                        <img src="~/ATS-LOGO.png" alt="" class="app-brand-image" />
                    </span>
                }
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i> Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-controller="Home" asp-action="Dashboard">
                                <i class="bi bi-grid-1x2 me-1"></i> Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-controller="Course" asp-action="Index">
                                <i class="bi bi-journal-bookmark me-1"></i> Courses
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-controller="Assessment" asp-action="Index">
                                <i class="bi bi-clipboard-check me-1"></i> Assessments
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-controller="Calendar" asp-action="Index">
                                <i class="bi bi-calendar-week me-1"></i> Calendar
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-controller="Home" asp-action="Privacy">
                                <i class="bi bi-shield-lock me-1"></i> Privacy
                            </a>
                        </li>
                    }
                </ul>

                <ul class="navbar-nav ms-auto align-items-center">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        var currentUser = await UserManager.GetUserAsync(User);
                        <li class="nav-item dropdown">
                            <a class="nav-link app-nav-link dropdown-toggle" href="#" id="user-menu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i> @(currentUser?.FirstName ?? User.Identity?.Name)
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="user-menu">
                                <li>
                                    <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">
                                        <i class="bi bi-person me-1"></i> Profile
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/ChangePassword">
                                        <i class="bi bi-key me-1"></i> Change Password
                                    </a>
                                </li>
                                <li>
                                    <div class="dropdown-item-text app-theme-menu-wrap">
                                        <span class="app-theme-menu-label">Theme</span>
                                        <button type="button" class="btn app-theme-toggle" data-theme-toggle aria-label="Switch between light mode and dark mode">
                                            <i class="bi bi-moon-stars-fill" data-theme-icon></i>
                                        </button>
                                    </div>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-box-arrow-right me-1"></i> Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-area="Identity" asp-page="/Account/Register">Register</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-area="Identity" asp-page="/Account/Login">Login</a>
                        </li>
                        <li class="nav-item ms-sm-2">
                            <button type="button" class="btn app-theme-toggle" data-theme-toggle aria-label="Switch between light mode and dark mode">
                                <i class="bi bi-moon-stars-fill" data-theme-icon></i>
                            </button>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>

<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer app-footer">
    <div class="container app-footer-content">
        <div>
            &copy; 2026 - Assessment Tracking System - Created with 💙 by Group 13 - 
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
