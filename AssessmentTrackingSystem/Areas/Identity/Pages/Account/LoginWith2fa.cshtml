@page
@model AssessmentTrackingSystem.Areas.Identity.Pages.Account.LoginWith2faModel

@{
    ViewData["Title"] = "Two-factor authentication";
}

<section class="auth-page-shell">
    <div class="auth-card auth-card--narrow">
        <div class="auth-card-header text-center">
            <h1 class="auth-card-title">@ViewData["Title"]</h1>
            <p class="auth-card-copy mb-0">Enter the 6-digit code from your authenticator app to finish signing in.</p>
        </div>

        <form method="post" asp-route-returnUrl="@Model.ReturnUrl" asp-route-rememberMe="@Model.RememberMe">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.TwoFactorCode" class="form-control" autocomplete="one-time-code" placeholder="123456" />
                <label asp-for="Input.TwoFactorCode"></label>
                <span asp-validation-for="Input.TwoFactorCode" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="Input.RememberMachine" class="form-check-input" />
                <label asp-for="Input.RememberMachine" class="form-check-label"></label>
            </div>

            <div class="auth-submit-wrap">
                <button type="submit" class="btn btn-lg btn-primary auth-submit-button">Verify code</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
