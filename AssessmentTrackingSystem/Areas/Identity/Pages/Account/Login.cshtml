@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<section class="auth-page-shell">
    <div class="auth-card auth-card--narrow">
        <div class="auth-card-header text-center">
            <h1 class="auth-card-title">@ViewData["Title"]</h1>
            <p class="auth-card-copy mb-0">Use your account credentials to continue</p>
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email" class="form-label">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                <label asp-for="Input.Password" class="form-label">Password</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <label asp-for="Input.RememberMe" class="form-check-label">
                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                </label>
            </div>

            <div class="auth-submit-wrap">
                <button id="login-submit" type="submit" class="btn btn-lg btn-primary auth-submit-button">Log in</button>
            </div>

            <div class="auth-card-links">
                <p>
                    <a id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a>
                </p>
                <p>
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register as a new user</a>
                </p>
                <p>
                    <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend email confirmation</a>
                </p>
            </div>
        </form>
    </div>

    <div class="auth-page-actions">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary auth-home-link">
            <i class="bi bi-arrow-left me-1"></i>
            Back
        </a>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
